# Threat Intelligence Dashboard - API Configuration

# VirusTotal API Key
# Get it from: https://www.virustotal.com/gui/settings/api
VT_API_KEY=your_api_key_here

# AbuseIPDB API Key
# Get it from: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=your_api_key_here

# GreyNoise Community API Key (replaces Shodan)
# Free signup at: https://www.greynoise.io/
GREYNOISE_API_KEY=your_api_key_here

# CrowdSec CTI API Key (replaces AlienVault OTX)
# Free signup at: https://app.crowdsec.net/
CROWDSEC_API_KEY=your_api_key_here

# IPinfo Token (replaces ip-api geolocation)
# Free tier: 50,000 requests/month — signup at: https://ipinfo.io/
IPINFO_TOKEN=your_token_here

# URLhaus API Key (Optional - uses public by default)
URLHAUS_API_KEY=public
