# Threat Intelligence Dashboard - API Configuration

# VirusTotal API Key
# Get it from: https://www.virustotal.com/gui/settings/api
VIRUSTOTAL_API_KEY=your_api_key_here

# AbuseIPDB API Key
# Get it from: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=your_api_key_here

# Shodan API Key
# Get it from: https://developer.shodan.io/
SHODAN_API_KEY=your_api_key_here

# AlienVault OTX API Key (Optional)
# Get it from: https://otx.alienvault.com/api
OTXAPI_KEY=your_api_key_here

# URLhaus API Key (Optional - uses public by default)
URLHAUS_API_KEY=public
